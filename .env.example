# Chat AI — use Groq for free tier without a credit card (recommended for fun projects)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Optional: llama-3.1-8b-instant (default), llama-3.3-70b-versatile, etc.
# GROQ_MODEL=llama-3.1-8b-instant
# CHAT_PROVIDER=groq

# Gemini API (chat) — optional; Google may require billing on some accounts
# GEMINI_API_KEY=your-gemini-api-key

# Flask session signing (use a long random string in production)
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# Google OAuth (Sign in with Google) — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add both for local + Render):
#   http://127.0.0.1:5000/auth/google/callback
#   https://YOUR-SERVICE.onrender.com/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: separate pepper for usage-limit hashing
# USAGE_LIMIT_PEPPER=wakuwaku-usage-pepper

# Render / cloud: set DISABLE_PIPER=1 on Free tier (browser TTS still works)
# DISABLE_PIPER=1

# Convex — after `npm run dev` or `npx convex dev --once`, see `.env.local` for:
# CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional: USE_CONVEX_USAGE=0 to use local data/daily_usage.json instead of Convex
# Optional: USE_CONVEX_FRONTEND=0 to disable Convex in the browser (Flask OAuth fallback)

# Convex Auth — set in Convex dashboard (or scripts/), not in this .env file:
# AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, SITE_URL, JWT_PRIVATE_KEY, JWKS
# See CONVEX_AUTH.md
